package wavelet:meta@0.1.0;

// Code as a WIT type (design.md §6.2).
//
// Homoiconicity has to survive the component boundary, so "a form" is itself a
// WIT type. WIT has no recursive types, so a form tree is encoded as an arena:
// a flat node table plus a root index. This mirrors `src/form.rs`
// (`Arena`/`Node`/`NodeId`) exactly.
//
// A call is just a `tup` whose first element is the head — there is no separate
// `call` node, matching `form::Node` (which has no `Call` variant).
interface code {
  type node-id = u32;

  variant node {
    bool-val(bool),
    int-val(s64),
    dec-val(f64),
    char-val(char),
    str-val(string),
    sym(string),
    qsym(tuple<string, string>),       // (alias, name)
    tup(list<node-id>),                // a call is a tup whose head is items[0]
    lst(list<node-id>),
    rec(list<tuple<string, node-id>>),
    flg(list<string>),
  }

  record tree {
    nodes: list<node>,
    root: node-id,
    spans: list<tuple<u32, u32>>,      // source offsets, parallel to nodes
  }
}

// Macros are components (design.md §6.3).
//
// A component exporting `wavelet:meta/macros` is a macro library. The compiler
// instantiates it at build time, calls `manifest` to learn each macro's
// `(name, arity)` (so the reader knows TitleCase arities across components),
// and routes expansion through `expand`: it marshals the call's argument forms
// into a `tree`, calls `expand(name, args)`, and lifts the returned `tree` back
// into the form arena. Macros are thus sandboxed by construction — a macro guest
// runs with no ambient capabilities.
interface macros {
  use code.{tree};

  // The macros this library publishes, as `(name, arity)` pairs. Arity is the
  // number of argument forms the macro head consumes (TitleCase arity reading,
  // §2.4).
  manifest: func() -> list<tuple<string, u32>>;

  // Expand one macro call. `name` is the macro's published name; `args` is the
  // call's argument forms bundled into a single `tree` (its `root` is a `tup`
  // whose elements are the arguments). Returns the rewritten form `tree`, or an
  // error string the compiler surfaces as an expansion failure.
  expand: func(name: string, args: tree) -> result<tree, string>;
}
