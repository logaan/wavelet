// The world a *produced* Wavelet macro-library component targets: it exports
// the `wavelet:meta/macros` interface (and nothing else), so the Step 1–8
// consumer can import it with `macros: true`. Mirrors the hand-built fixture's
// world (`tests/fixtures/macros/wit/world.wit`); the difference is that this
// guest's `manifest`/`expand` are driven by an embedded Wavelet macro file run
// through the bundled interpreter (Step 9, strategy A), not hand-written Rust.
package wavelet:macro-guest@0.1.0;

world macro-lib {
  export wavelet:meta/macros@0.1.0;
}
